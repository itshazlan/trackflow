# Database Configuration
POSTGRES_DB=trackflow
POSTGRES_USER=trackflow
POSTGRES_PASSWORD=ganti_dengan_password_aman_di_produksi

# Better Auth Configuration
BETTER_AUTH_SECRET=ganti_dengan_secret_random_panjang_minimal_32_karakter
BETTER_AUTH_URL=https://trackflow.domainanda.com/api/auth

# Cloudflare R2 Configuration (Untuk screenshot uploads)
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=trackflow
