    {
      "name": "Issues",
      "description": "Core issue/ticket management with direct and template-based creation, and role-restricted status transitions.",
      "item": [
        {
          "name": "My Dashboard Issues",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "{{sessionCookie}}" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/issues",
              "host": ["{{baseUrl}}"],
              "path": ["issues"]
            },
            "description": "Returns all issues assigned to or created by the authenticated user across all projects."
          }
        },
        {
          "name": "Create Issue (Direct)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.id) { pm.collectionVariables.set('issueId', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "{{sessionCookie}}" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trackerId\": \"<tracker-uuid>\",\n  \"title\": \"Fix pagination on dashboard\",\n  \"description\": \"The dashboard pagination resets on filter change.\",\n  \"priority\": \"high\",\n  \"assigneeId\": null,\n  \"startDate\": \"2026-07-15\",\n  \"dueDate\": \"2026-07-20\",\n  \"estimatedHours\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/issues",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "issues"]
            },
            "description": "Creates an issue with direct title/description. If `statusId` is omitted, defaults to the project's first status (orderIndex=0). Priority: `low`, `medium`, `high`, `urgent`."
          }
        },
        {
          "name": "Create Issue (From Template)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "{{sessionCookie}}" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "body": {
              "mode": "raw",
