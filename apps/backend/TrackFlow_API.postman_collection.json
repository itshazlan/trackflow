{
  "info": {
    "_postman_id": "trackflow-api-collection",
    "name": "TrackFlow Backend API",
    "description": "Complete REST API collection for the TrackFlow internal time-tracking and project management system.\n\n**Base URL**: `{{baseUrl}}` (default: `http://localhost:3000`)\n\n**Authentication**: Cookie-based via Better Auth. Call `POST /api/auth/sign-in/email` first — the session cookie is automatically saved to the `sessionCookie` variable and used on all subsequent requests.\n\n**Setup**:\n1. Import this collection into Postman.\n2. Create an Environment with variable `baseUrl = http://localhost:3000`.\n3. Run `Auth / Sign In (Admin)` to get a session.\n4. Proceed to use any module endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "sessionCookie",
      "value": "",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "issueId",
      "value": "",
      "type": "string"
    },
    {
      "key": "timeBlockId",
      "value": "",
      "type": "string"
    },
    {
      "key": "timesheetId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Better Auth endpoints for email/password registration, sign-in, session, and sign-out.",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@trackflow.com\",\n  \"password\": \"Password123!\",\n  \"name\": \"New User\",\n  \"username\": \"newuser\",\n  \"position\": \"Developer\",\n  \"department\": \"Engineering\",\n  \"employeeId\": \"EMP-001\",\n  \"employmentStatus\": \"active\",\n  \"isAdmin\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-up/email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "sign-up", "email"]
            },
            "description": "Register a new employee account via Better Auth. `isAdmin` and `employeeId` are optional and handled as additionalFields."
          }
        },
        {
          "name": "Sign In (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const cookie = pm.response.headers.get('Set-Cookie');",
                  "if (cookie) { pm.collectionVariables.set('sessionCookie', cookie); }",
                  "const json = pm.response.json();",
                  "if (json && json.user) { pm.collectionVariables.set('userId', json.user.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@trackflow.com\",\n  \"password\": \"AdminPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-in/email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "sign-in", "email"]
            },
            "description": "Sign in and automatically saves the session cookie to `sessionCookie` collection variable."
          }
        },
        {
          "name": "Get Current Session",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "{{sessionCookie}}" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/session",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "session"]
            },
            "description": "Returns the currently active session including the authenticated user object."
          }
        },
        {
          "name": "Sign Out",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Cookie", "value": "{{sessionCookie}}" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-out",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "sign-out"]
            }
          }
        }
      ]
    },
