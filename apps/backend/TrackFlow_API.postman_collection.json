    {
      "name": "Time Tracking",
      "description": "Core time tracking: desktop client sync, screenshot metadata, queries, self-deletion, and admin overrides.",
      "item": [
        {
          "name": "Sync Time Block",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.timeBlock && json.timeBlock.id) { pm.collectionVariables.set('timeBlockId', json.timeBlock.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "{{sessionCookie}}" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"{{projectId}}\",\n  \"issueId\": null,\n  \"blockStart\": \"2026-07-14T09:00:00.000Z\",\n  \"blockEnd\": \"2026-07-14T09:10:00.000Z\",\n  \"activity\": {\n    \"keyboardCount\": 342,\n    \"mouseCount\": 88,\n    \"activeAppName\": \"Visual Studio Code\",\n    \"activeWindowTitle\": \"trackflow-backend — main.ts\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/time-blocks/sync",
              "host": ["{{baseUrl}}"],
              "path": ["time-blocks", "sync"]
            },
            "description": "Primary sync endpoint called by the desktop client every 10 minutes. Validates project membership. Computes `activityLevel` from total inputs (none/low/medium/high). Calculates `purgeAfter` from `app_settings.screenshotRetentionDays`. Returns the created `timeBlock` and `activityLog`."
          }
        },
        {
          "name": "Upload Screenshot",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Cookie", "value": "{{sessionCookie}}" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/time-blocks/{{timeBlockId}}/screenshot",
              "host": ["{{baseUrl}}"],
              "path": ["time-blocks", "{{timeBlockId}}", "screenshot"]
            },
            "description": "Uploads a screenshot file (multipart/form-data) associated with a time block. Stores on disk at `uploads/screenshots/` with a random hash filename. Returns the created screenshot record."
          }
        },
        {
          "name": "List My Time Blocks",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "{{sessionCookie}}" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/time-blocks?projectId={{projectId}}&startDate=2026-07-01&endDate=2026-07-31",
              "host": ["{{baseUrl}}"],
              "path": ["time-blocks"],
              "query": [
                { "key": "projectId", "value": "{{projectId}}", "description": "Filter by project (optional)" },
                { "key": "startDate", "value": "2026-07-01", "description": "ISO date (optional)" },
                { "key": "endDate", "value": "2026-07-31", "description": "ISO date (optional)" }
              ]
            },
            "description": "Returns all non-deleted time blocks for the authenticated user. Joins with activity logs and screenshots."
          }
        },
        {
          "name": "Self Delete Time Block",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "{{sessionCookie}}" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Accidentally tracked personal task\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/time-blocks/{{timeBlockId}}",
              "host": ["{{baseUrl}}"],
              "path": ["time-blocks", "{{timeBlockId}}"]
            },
            "description": "Soft-deletes a worker's own time block. Sets `isDeleted=true`, `deletionType='self'`, and creates an audit log entry."
          }
        },
        {
          "name": "Admin Override Time Block",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "{{sessionCookie}}" },
              { "key": "Origin", "value": "{{baseUrl}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"mark_unpaid\",\n  \"reason\": \"Non-work related activities detected\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/time-blocks/{{timeBlockId}}/override",
              "host": ["{{baseUrl}}"],
              "path": ["time-blocks", "{{timeBlockId}}", "override"]
            },
            "description": "**Admin only.** `action`: `delete` (soft-delete) or `mark_unpaid` (sets `isPaid=false`). A mandatory `reason` is always recorded in the audit log."
          }
        }
      ]
    },
