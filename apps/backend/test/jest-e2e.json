{
  "moduleFileExtensions": ["js", "json", "ts", "mjs"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j|mj)s$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(better-auth)/)"
  ],
  "setupFiles": ["dotenv/config"]
}
