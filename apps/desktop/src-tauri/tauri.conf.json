{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trackflow Desktop",
  "version": "0.2.0",
  "identifier": "com.trackflow.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Trackflow Desktop",
        "width": 460,
        "height": 580
      },
      {
        "label": "screenshot-widget",
        "title": "Screenshot Review",
        "width": 280,
        "height": 180,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": true,
        "shadow": false,
        "visible": false
      },
      {
        "label": "screenshot-preview",
        "title": "Screenshot Preview",
        "width": 800,
        "height": 600,
        "decorations": true,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data:; connect-src 'self' http://localhost:3000; style-src 'self' 'unsafe-inline';",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/*",
          "$APPDATA/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE0RjE1NTJEODNEMEExMTUKUldRVm9kQ0RMVlh4cEZOdWhweTg0c014RVRPZGJUTEVVUTU1bU9kNXRhRDd5elkrZUZ1V3B2ZUMK",
      "endpoints": [
        "https://localhost:3000/desktop-updater/{{target}}/{{current_version}}"
      ]
    }
  }
}
